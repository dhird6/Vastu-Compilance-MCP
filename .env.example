APP_NAME=Vastu Compliance MCP Server
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APS_CLIENT_ID=your_aps_client_id
APS_CLIENT_SECRET=your_aps_client_secret
APS_AUTH_URL=https://developer.api.autodesk.com/authentication/v2/token
APS_API_BASE_URL=https://developer.api.autodesk.com
RULES_PATH=config/vastu_rules.yaml
VEDIC_KNOWLEDGE_PATH=config/vedic_knowledge.yaml
LOG_LEVEL=INFO

# OpenAI (optional — template fallback when empty)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# PostgreSQL + pgvector (optional — in-memory YAML when empty)
DATABASE_URL=postgresql+asyncpg://vastu:vastu@localhost:5432/vastu
